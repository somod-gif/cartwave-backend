# ─── CartWave Backend — Environment Variables ────────────────────────────────
# This file is loaded automatically by spring-dotenv.
# NEVER commit real credentials to version control.
# See ENV_VARIABLES.md for full documentation.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# On Render, set DATABASE_URL instead — the app checks DATABASE_URL first,
# then falls back to DB_URL   (see application.yaml).
# NOTE: channel_binding=require was REMOVED — Neon's PgBouncer pooler does
#       not support channel binding and connections will fail with it enabled.
DB_URL=jdbc:postgresql://ep-calm-recipe-a8grcm8w-pooler.eastus2.azure.neon.tech/neondb?sslmode=require&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_3O5mDpeQZxRg

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=cW92F7kXpL3mZ8nRjY5vBwHsD0TqUaE6gKxC1iNoP4dAfJtMlWyS9bVu2hGrIeQ
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
CORS_ALLOWED_ORIGINS=*

# ─── Mail (MailHog / MailPit for local dev) ──────────────────────────────────
# For production, set real SMTP credentials (e.g. SendGrid, Mailgun, SES).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
