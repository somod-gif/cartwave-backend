# ─── CartWave Backend — Environment Variables ────────────────────────────────
# Loaded automatically by spring-dotenv on startup.
# NEVER commit real credentials to version control.
# See ENV_GUIDE.md for step-by-step instructions on getting each value.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://ep-calm-recipe-a8grcm8w-pooler.eastus2.azure.neon.tech/neondb?sslmode=require&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_3O5mDpeQZxRg

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=cW92F7kXpL3mZ8nRjY5vBwHsD0TqUaE6gKxC1iNoP4dAfJtMlWyS9bVu2hGrIeQ
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
CORS_ALLOWED_ORIGINS=*

# ─── Mail (Resend SMTP) ─────────────────────────────────────────────────────
# Resend docs: https://resend.com/docs/send-with-smtp
RESEND_API_KEY=re_fXuLpoxn_PAk19CfkcbeFYgkqJkCTDr6a
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=re_fXuLpoxn_PAk19CfkcbeFYgkqJkCTDr6a
SMTP_AUTH=true
SMTP_STARTTLS=false
SMTP_SSL=true
# From address — must use a domain you verified in Resend dashboard
# Until you verify a domain, use: onboarding@resend.dev (Resend test address)
MAIL_FROM=onboarding@resend.dev

# ─── AWS S3 (product image uploads) ─────────────────────────────────────────
# Leave blank for local dev — image upload endpoints will return 500 unless AWS is configured.
# See ENV_GUIDE.md → "Getting AWS credentials" section.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET_NAME=cartwave-assets
AWS_S3_BASE_URL=https://cartwave-assets.s3.eu-west-1.amazonaws.com

# ─── Super Admin seed credentials ────────────────────────────────────────────
# These are only used on FIRST startup to seed the super admin user.
# Change the password immediately after first login.
SUPERADMIN_EMAIL=superadmin@cartwave.local
SUPERADMIN_PASSWORD=Password123!
